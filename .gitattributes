# Auto-detect text files, normalize to LF in repository
* text=auto

# Force LF for scripts — critical for cross-platform execution
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Force LF for hook scripts (no extension)
.hooks/* text eol=lf

# Force LF for configuration and documentation
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.md text eol=lf
*.tex text eol=lf
*.bib text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.json text eol=lf
Makefile text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.pdf binary
*.eps binary
*.zip binary
*.gz binary
*.tar binary
*.bz2 binary
*.7z binary
*.xz binary
*.xlsx binary
*.xls binary
*.parquet binary
*.h5 binary
*.hdf5 binary
*.npy binary
*.npz binary
*.pkl binary
*.pickle binary
*.joblib binary
*.pt binary
*.pth binary
*.safetensors binary
*.onnx binary
*.sqlite binary
*.db binary
*.nc binary
*.arrow binary
*.feather binary
*.dmg binary
*.woff binary
